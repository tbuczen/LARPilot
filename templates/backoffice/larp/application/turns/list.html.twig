{% extends 'backoffice/larp/base.html.twig' %}

{% block larp_title %}{{ 'application_turn.list'|trans }}{% endblock %}

{% block larp_content %}
    <div class="card mt-4">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-center">
                <h2 class="mb-0">{{ 'application_turn.list'|trans }}</h2>
                <a href="{{ path('backoffice_larp_application_turns_create', {larp: larp.id}) }}" class="btn btn-success">
                    {{ 'create'|trans }}
                </a>
            </div>
            <p class="mb-0 mt-1 text-muted small">{{ 'application_turn.list_help'|trans }}</p>
        </div>
        <div class="card-body p-0">
            {% if turns is not empty %}
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>{{ 'application_turn.round_number'|trans }}</th>
                                <th>{{ 'application_turn.opens_at'|trans }}</th>
                                <th>{{ 'application_turn.closes_at'|trans }}</th>
                                <th>{{ 'application_turn.price'|trans }}</th>
                                <th>{{ 'status'|trans }}</th>
                                <th>{{ 'actions'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for turn in turns %}
                                <tr>
                                    <td>
                                        <a href="{{ path('backoffice_larp_application_turns_edit', {larp: larp.id, turn: turn.id}) }}">
                                            {{ 'application_turn.round'|trans }} {{ turn.roundNumber }}
                                        </a>
                                    </td>
                                    <td>{{ turn.opensAt ? turn.opensAt|date('Y-m-d H:i') : '-' }}</td>
                                    <td>{{ turn.closesAt ? turn.closesAt|date('Y-m-d H:i') : '-' }}</td>
                                    <td>{{ turn.price ? turn.price ~ ' zł' : '-' }}</td>
                                    <td>
                                        {% if turn.open %}
                                            <span class="badge bg-success">{{ 'application_turn.status_open'|trans }}</span>
                                        {% else %}
                                            <span class="badge bg-secondary">{{ 'application_turn.status_closed'|trans }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <a href="{{ path('backoffice_larp_application_turns_edit', {larp: larp.id, turn: turn.id}) }}"
                                           class="btn btn-sm btn-outline-primary me-1">{{ 'edit'|trans }}</a>
                                        <button type="button" class="btn btn-sm btn-danger"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteModal"
                                                data-item-id="{{ turn.id }}"
                                                data-item-name="{{ 'application_turn.round'|trans }} {{ turn.roundNumber }}"
                                                data-delete-url="{{ path('backoffice_larp_application_turns_delete', {larp: larp.id, turn: turn.id}) }}">
                                            {{ 'delete'|trans }}
                                        </button>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <p class="text-muted p-3">{{ 'empty_list'|trans }}</p>
            {% endif %}
        </div>
    </div>

    {% include 'includes/delete_modal.html.twig' %}
{% endblock %}
